{
  "name": "n8n-nodes-socialmate",
  "version": "2.4.2",
  "description": "n8n community node for SocialMate — automate WhatsApp messaging through your self-hosted SocialMate desktop server (send/schedule/bulk messages, manage chats, contacts, groups, media, and react to incoming messages).",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-node",
    "socialmate",
    "whatsapp",
    "whatsapp-automation",
    "automation",
    "messaging",
    "self-hosted"
  ],
  "license": "MIT",
  "homepage": "https://socialmate.app",
  "author": {
    "name": "SocialMate",
    "email": "admin@socialmate.app",
    "url": "https://socialmate.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/micbwilliam/n8n-nodes-socialmate.git"
  },
  "bugs": {
    "url": "https://socialmate.app/support"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "prepack": "node scripts/prepack.mjs",
    "postpack": "node scripts/postpack.mjs",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SocialMateApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SocialMate/SocialMate.node.js",
      "dist/nodes/SocialMateTrigger/SocialMateTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/node": "^22.10.0",
    "@typescript-eslint/parser": "^7.18.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.3",
    "semantic-release": "^24.2.9",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
